# Example environment variables for frontend
# Copy this to .env.local and configure for your setup

# API URL - Backend endpoint
VITE_API_URL=http://localhost:3001/api

# For production deployment (Vercel), set this to your deployed backend URL:
# VITE_API_URL=https://your-backend-domain.vercel.app/api

# OpenAI Configuration for AI Features
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here

# Optional: GPT Model Configuration
VITE_AI_MODEL=gpt-4o-mini
VITE_AI_TEMPERATURE=0.3
VITE_AI_MAX_TOKENS=1000

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_VOICE_RECOGNITION=false
VITE_ENABLE_ADVANCED_ANALYTICS=true
