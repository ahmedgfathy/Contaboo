# Frontend Environment Variables
# This file is for production deployment on Vercel

# For production, use relative path since backend is deployed to same domain
VITE_API_URL=/api

# OpenAI Configuration (will be overridden by Vercel environment variables)
VITE_OPENAI_API_KEY=your_openai_key_here

# AI Configuration
VITE_AI_MODEL=gpt-4o-mini
VITE_AI_TEMPERATURE=0.3
VITE_AI_MAX_TOKENS=1000

# Feature Flags
VITE_ENABLE_AI_FEATURES=true
